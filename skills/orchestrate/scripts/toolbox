#!/usr/bin/env bash
# toolbox [--refresh] — probe this repo's orientation tooling (pure shell, zero
# tokens) and write .orchestrate/toolbox.md: which structure/outline recipes
# work HERE, plus manifests and conventions files. Workers read the file
# instead of burning tool calls re-probing. Idempotent; --refresh regenerates.
set -euo pipefail

root="$(git rev-parse --show-toplevel 2>/dev/null || pwd)"
ws="$root/.orchestrate"; mkdir -p "$ws"
out="$ws/toolbox.md"
if [ -f "$out" ] && [ "${1:-}" != "--refresh" ]; then printf '%s\n' "$out"; exit 0; fi

have() { command -v "$1" >/dev/null 2>&1; }

if have tree; then
  structure='tree -L 3 --dirsfirst --gitignore -I "node_modules|dist|build" <dir>'
elif have eza; then
  structure='eza --tree --level=3 --git-ignore <dir>'
else
  structure='git ls-files "<dir>/*" | head -80    # gitignore-aware; or the Glob tool'
fi

if have ast-grep; then
  outline='ast-grep run -p "function $F($$$) { $$$ }" <file>    # structural; swap pattern per language'
elif have ctags; then
  outline='ctags -x --sort=no <file> | head -40'
else
  outline='grep -nE "^(export |def |class |func |function |const [A-Z]|interface |type )" <file>'
fi

manifests=""
for m in package.json pyproject.toml go.mod Cargo.toml Gemfile composer.json mix.exs build.gradle pom.xml; do
  [ -f "$root/$m" ] && manifests="$manifests $m"
done
manifests="${manifests# }"; [ -n "$manifests" ] || manifests="(none found at root)"

pkgmgr="(unknown)"
[ -f "$root/package-lock.json" ] && pkgmgr="npm"
[ -f "$root/yarn.lock" ]        && pkgmgr="yarn"
[ -f "$root/pnpm-lock.yaml" ]   && pkgmgr="pnpm"
[ -f "$root/bun.lockb" ] || [ -f "$root/bun.lock" ] && pkgmgr="bun"
[ -f "$root/poetry.lock" ]      && pkgmgr="poetry"
[ -f "$root/uv.lock" ]          && pkgmgr="uv"
[ -f "$root/Cargo.lock" ]       && pkgmgr="cargo"
[ -f "$root/go.sum" ]           && pkgmgr="go"

conventions=""
for c in CLAUDE.md AGENTS.md CONTRIBUTING.md .editorconfig; do
  [ -f "$root/$c" ] && conventions="$conventions $c"
done
conventions="${conventions# }"; [ -n "$conventions" ] || conventions="(none found)"

extras=""
for t in tree eza ast-grep ctags fd rg jq; do have "$t" && extras="$extras $t"; done
extras="${extras# }"; [ -n "$extras" ] || extras="(base tools only)"

cat > "$out" <<EOF
# toolbox — orientation recipes for this repo (generated by scripts/toolbox; --refresh to redo)

structure:    $structure
outline:      $outline
search:       the Grep tool (ripgrep-backed) — files_with_matches first, then targeted reads
recency:      git log --oneline -10 · git diff --stat HEAD~5 2>/dev/null

manifests:    $manifests
pkg manager:  $pkgmgr
conventions:  $conventions
installed:    $extras

Read this file INSTEAD of probing for tools. Orientation ritual: shared/token-economy.md.
EOF

printf '%s\n' "$out"
