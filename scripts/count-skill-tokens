#!/usr/bin/env python3
"""Print stable word-based token estimates for the runtime skill files."""

from __future__ import annotations

import math
import re
from pathlib import Path


root = Path(__file__).resolve().parents[1]
skill_dirs = sorted(path for path in (root / "skills").iterdir() if path.is_dir())
if len(skill_dirs) != 1 or skill_dirs[0].name == "__SKILL_NAME__":
    raise SystemExit("count-skill-tokens: instantiate exactly one skill first")

skill = skill_dirs[0]
total = 0
for path in sorted(path for path in skill.rglob("*") if path.is_file() and path.suffix in {".md", ".yaml", ".yml"}):
    text = path.read_text(encoding="utf-8")
    estimate = math.ceil(len(re.findall(r"\b\w+\b", text)) * 1.35)
    total += estimate
    print(f"{estimate:6d}  {path.relative_to(root)}")
print(f"{total:6d}  total estimated tokens")
